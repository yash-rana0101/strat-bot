# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Strat AI Discord Bot Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Discord Bot Token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_bot_token_here

# Discord Application Client ID
CLIENT_ID=your_client_id_here

# Target Guild (Server) ID
GUILD_ID=your_guild_id_here

# Database Connection URL (Supabase direct postgres:// link)
DATABASE_URL=your_direct_postgres_url_here

# Log level (debug | info | warn | error)
LOG_LEVEL=info

# Bot status message
BOT_STATUS=stratai.live | Market Intelligence

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Discord Application URLs
# Configure these in Discord Developer Portal → General Information
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Interactions Endpoint URL (optional — only if using HTTP-based interactions instead of Gateway)
INTERACTIONS_ENDPOINT_URL=

# Linked Roles Verification URL (optional — for role connections)
LINKED_ROLES_VERIFICATION_URL=

# Terms of Service URL
TERMS_OF_SERVICE_URL=https://stratai.live/terms-of-service

# Privacy Policy URL
PRIVACY_POLICY_URL=https://stratai.live/privacy-policy
